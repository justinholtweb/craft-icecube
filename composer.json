{
    "name": "justinholtweb/craft-icecube",
    "description": "Lock entries, assets, categories, and globals behind a password in Craft CMS.",
    "type": "craft-plugin",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.2",
        "craftcms/cms": "^5.3.0"
    },
    "autoload": {
        "psr-4": {
            "justinholtweb\\icecube\\": "src/"
        }
    },
    "extra": {
        "name": "Icecube",
        "handle": "icecube",
        "hasCpSettings": true,
        "hasCpSection": false,
        "class": "justinholtweb\\icecube\\Icecube"
    }
}
