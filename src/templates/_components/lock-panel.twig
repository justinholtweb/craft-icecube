{# Icecube inline lock-management panel for element edit pages #}
{% set lockEdit = lock is not null ? lock.lockEdit : true %}
{% set lockDelete = lock is not null ? lock.lockDelete : true %}
{% set notes = lock is not null ? lock.notes : '' %}
{% set hasPassword = lock is not null and lock.passwordHash is not empty %}

<div class="icecube-inline-panel" data-icecube-panel
     data-target-type="{{ targetType }}"
     data-target-id="{{ targetId }}">

    <div class="icecube-inline-panel__header">
        <h3>
            <span class="icecube-inline-panel__icon">{{ lock ? '🔒' : '🔓' }}</span>
            {{ 'Icecube Lock'|t('icecube') }}
        </h3>
        <p class="icecube-inline-panel__status" data-icecube-status>
            {% if lock %}
                {% if lock.lockEdit and lock.lockDelete %}
                    {{ 'This {label} is locked for edit + delete.'|t('icecube', { label: label }) }}
                {% elseif lock.lockEdit %}
                    {{ 'This {label} is locked for edit.'|t('icecube', { label: label }) }}
                {% elseif lock.lockDelete %}
                    {{ 'This {label} is locked for delete.'|t('icecube', { label: label }) }}
                {% endif %}
            {% else %}
                {{ 'This {label} is not locked.'|t('icecube', { label: label }) }}
            {% endif %}
        </p>
    </div>

    <div class="icecube-inline-panel__fields">
        <label class="icecube-inline-panel__toggle">
            <input type="checkbox" data-icecube-field="lockEdit" {{ lockEdit ? 'checked' : '' }}>
            {{ 'Lock editing'|t('icecube') }}
        </label>

        <label class="icecube-inline-panel__toggle">
            <input type="checkbox" data-icecube-field="lockDelete" {{ lockDelete ? 'checked' : '' }}>
            {{ 'Lock deletion'|t('icecube') }}
        </label>

        <label class="icecube-inline-panel__label">{{ 'Notes'|t('icecube') }}</label>
        <input type="text" class="text fullwidth" data-icecube-field="notes"
               value="{{ notes }}" placeholder="{{ 'Optional description'|t('icecube') }}">

        <label class="icecube-inline-panel__label">
            {{ 'Password'|t('icecube') }}
            <span class="icecube-inline-panel__hint">
                {% if hasPassword %}
                    {{ 'leave blank to keep current'|t('icecube') }}
                {% else %}
                    {{ 'leave blank to use master password'|t('icecube') }}
                {% endif %}
            </span>
        </label>
        <input type="password" class="text fullwidth" data-icecube-field="password"
               autocomplete="new-password" placeholder="••••••••">
    </div>

    <div class="icecube-inline-panel__actions">
        <button type="button" class="btn submit" data-icecube-action="save">
            {% if lock %}
                {{ 'Update lock'|t('icecube') }}
            {% else %}
                {{ 'Lock this {label}'|t('icecube', { label: label }) }}
            {% endif %}
        </button>
        {% if lock %}
            <button type="button" class="btn" data-icecube-action="delete">
                {{ 'Remove lock'|t('icecube') }}
            </button>
        {% endif %}
    </div>

    <div class="icecube-inline-panel__message" data-icecube-message style="display:none;"></div>
</div>
