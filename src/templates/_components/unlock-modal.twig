{#
  Icecube unlock modal. Shown on page load for locked-for-edit elements,
  or on demand when a delete is attempted on a locked-for-delete element.
#}

<div id="icecube-unlock-modal" class="icecube-modal" style="display:none;">
    <div class="icecube-modal-backdrop"></div>
    <div class="icecube-modal-body">
        <div class="icecube-modal-icon">🔒</div>
        <h2>This item is locked</h2>
        <p>Enter the unlock password to make changes. The unlock stays valid for the rest of your session.</p>

        <form id="icecube-unlock-form">
            <div class="field">
                <div class="input">
                    <input type="password"
                           id="icecube-password"
                           name="password"
                           class="text fullwidth"
                           placeholder="Unlock password"
                           autocomplete="off">
                </div>
            </div>

            <input type="hidden" id="icecube-target-type" name="targetType" value="">
            <input type="hidden" id="icecube-target-id" name="targetId" value="">
            <input type="hidden" id="icecube-action" name="action" value="">

            <div id="icecube-error" class="error" style="display:none;"></div>

            <div class="icecube-modal-footer">
                <button type="button" class="btn" id="icecube-cancel-btn">Go back</button>
                <button type="submit" class="btn submit">Unlock</button>
            </div>
        </form>
    </div>
</div>
